# Production (Vercel): Postgres connection string. Locally you can point this
# at a local Postgres instance, or keep using SQLite in your own untracked .env.
DATABASE_URL=""

# ── Admin login ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=""
# Generate with: npm run hash-password -- "your-password"
ADMIN_PASSWORD_HASH=""
# Generate with: openssl rand -base64 32
SESSION_SECRET=""

